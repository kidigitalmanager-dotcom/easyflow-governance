# UseEasy API – Environment Variables
# Copy to .env for local development, set in Lambda env for production.

# Shared API key for X-Api-Key header authentication
API_KEY=useeasy-dev-key-change-me

# Bedrock Model ID (eu-central-1)
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514

# Log level (info, warn, error, debug)
LOG_LEVEL=info

# AWS Region (set by SAM, override for local)
# AWS_REGION=eu-central-1
